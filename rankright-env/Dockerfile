# -------------------------------
# BASE IMAGE
# -------------------------------
FROM python:3.11-slim

# -------------------------------
# SET WORKDIR
# -------------------------------
WORKDIR /app

# -------------------------------
# COPY FILES
# -------------------------------
COPY . .

# -------------------------------
# INSTALL DEPENDENCIES
# -------------------------------
RUN pip install --no-cache-dir -r requirements.txt

# -------------------------------
# EXPOSE PORT
# -------------------------------
EXPOSE 7860

# -------------------------------
# RUN APP
# -------------------------------
CMD ["uvicorn", "app.api:app", "--host", "0.0.0.0", "--port", "7860"]